{
  "manifest_version": 3,
  "name": "Markdown Editor & Formatter",
  "version": "1.1.4",
  "description": "一个功能强大的Markdown编辑器，支持实时预览、格式化和快速复制",
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs"
  ],
  "action": {
    "default_title": "Markdown Editor - 点击在新标签页中打开"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["lib/marked.min.js", "fullscreen.html", "fullscreen.js", "styles/fullscreen.css", "lib/highlight.min.js"],
    "matches": ["<all_urls>"]
  }]
}