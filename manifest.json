{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.1.5",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "__MSG_openNewTab__"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["lib/marked.min.js", "lib/dompurify.min.js", "fullscreen.html", "fullscreen.js", "styles/fullscreen.css", "lib/highlight.min.js", "scripts/i18n.js"],
    "matches": ["<all_urls>"]
  }]
}
