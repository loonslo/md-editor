{
  "manifest_version": 3,
  "name": "Markdown Editor - Side Panel",
  "version": "1.0.0",
  "description": "Markdown编辑器侧边栏版本，自适应80%浏览器窗口大小",
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Markdown Editor"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
